@model IEnumerable<CategoriesSystem.Models.Product>

<h2 class="mb-4">Products</h2>

<div class="row">
    @foreach (var product in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <img src="@product.ImagePath" class="card-img-top" style="height:200px; object-fit:cover;" />

                <div class="card-body">
                    <h5 class="card-title">@product.Name</h5>

                    <a asp-controller="Products"
                       asp-action="Details"
                       asp-route-id="@product.Id"
                       class="btn btn-success">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<a asp-controller="Categories" asp-action="Index" class="btn btn-secondary">
    Back to Categories
</a>